<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MedSystem.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MedSystem.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Единый акцент для обеих тем — стандартный синий Windows #0078D4.
                 В тёмной теме заливка светлее (как делает сама Windows),
                 чтобы кнопки и выделение читались. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#0078D4</Color>
                    <Color x:Key="SystemAccentColorLight1">#268CDC</Color>
                    <Color x:Key="SystemAccentColorLight2">#4CA0E0</Color>
                    <Color x:Key="SystemAccentColorLight3">#75B6E7</Color>
                    <Color x:Key="SystemAccentColorDark1">#006CBE</Color>
                    <Color x:Key="SystemAccentColorDark2">#005EA6</Color>
                    <Color x:Key="SystemAccentColorDark3">#005090</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#0078D4" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#006CBE" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#005EA6" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#0078D4" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#006CBE" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#005EA6" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#0078D4</Color>
                    <Color x:Key="SystemAccentColorLight1">#268CDC</Color>
                    <Color x:Key="SystemAccentColorLight2">#4CA0E0</Color>
                    <Color x:Key="SystemAccentColorLight3">#75B6E7</Color>
                    <Color x:Key="SystemAccentColorDark1">#006CBE</Color>
                    <Color x:Key="SystemAccentColorDark2">#005EA6</Color>
                    <Color x:Key="SystemAccentColorDark3">#005090</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#4CA0E0" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#268CDC" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#0078D4" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#75B6E7" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#4CA0E0" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#268CDC" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
