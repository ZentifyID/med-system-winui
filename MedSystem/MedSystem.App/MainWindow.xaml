<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MedSystem.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Кастомный заголовок окна (контент продлён под титлбар) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center" Margin="16,0,0,0">
                <FontIcon Glyph="&#xE95E;" FontSize="14"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="Med System" Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <NavigationView
            x:Name="Nav"
            Grid.Row="1"
            PaneDisplayMode="Auto"
            OpenPaneLength="220"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            SelectionChanged="Nav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Главная" Tag="home" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Сотрудники" Tag="employees">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Студенты" Tag="students">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Лекарства" Tag="medicines">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE95E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Обращения" Tag="appeals">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Контент на «слое» со скруглённым углом, как в Параметрах Windows -->
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,1,0,0"
                    CornerRadius="8,0,0,0">
                <Frame x:Name="ContentFrame" />
            </Border>
        </NavigationView>

        <!-- Уведомление о начале нового учебного года -->
        <InfoBar x:Name="StartupInfoBar"
                 Grid.Row="1"
                 Severity="Informational"
                 Title="Новый учебный год"
                 IsOpen="False"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Right"
                 Margin="0,0,24,24"
                 MaxWidth="480" />
    </Grid>
</Window>
