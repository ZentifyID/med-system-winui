<Page
    x:Class="MedSystem.App.Pages.StudentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MedSystem.App.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="Студенты" Style="{StaticResource TitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock x:Name="CountText" Text="" VerticalAlignment="Center" Opacity="0.6" />
                <Button Content="Группы" Click="GroupsButton_Click" />
                <Button Content="+ Добавить" Style="{StaticResource AccentButtonStyle}"
                        Click="AddButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     PlaceholderText="Поиск по ФИО..."
                     TextChanged="SearchBox_TextChanged" />
            <ComboBox x:Name="FilterBox" Grid.Column="1" Margin="12,0,0,0"
                      MinWidth="200" SelectedIndex="0"
                      SelectionChanged="FilterBox_SelectionChanged">
                <x:String>Все студенты</x:String>
                <x:String>Просроченные</x:String>
                <x:String>Истекают (2 недели)</x:String>
            </ComboBox>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="16,12,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ФИО" FontSize="12" Opacity="0.6" />
                    <TextBlock Grid.Column="1" Text="Группа" FontSize="12" Opacity="0.6" />
                    <TextBlock Grid.Column="2" Text="Санминимум" FontSize="12" Opacity="0.6" />
                    <TextBlock Grid.Column="3" Text="Медосмотр" FontSize="12" Opacity="0.6" />
                    <TextBlock Grid.Column="4" Text="Флюорография" FontSize="12" Opacity="0.6" />
                </Grid>
                <Rectangle Grid.Row="1" Height="1" HorizontalAlignment="Stretch"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <ListView x:Name="StudentsList" Grid.Row="2" Margin="4,2,4,6" SelectionMode="Single"
                          IsDoubleTapEnabled="True" DoubleTapped="StudentsList_DoubleTapped">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:StudentRow">
                            <Grid Padding="4,10" Background="Transparent">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Открыть / Редактировать"
                                                        Tag="{x:Bind Id}" Click="OpenMenuItem_Click" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Удалить"
                                                        Tag="{x:Bind Id}" Click="DeleteMenuItem_Click" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind FullName}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind GroupName}" Opacity="0.8" VerticalAlignment="Center" />
                                <Border Grid.Column="2" Background="{x:Bind SanminimumBg}" CornerRadius="10"
                                Padding="10,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Sanminimum}" Foreground="{x:Bind SanminimumFg}" FontSize="12" />
                        </Border>
                                <Border Grid.Column="3" Background="{x:Bind MedicalExamBg}" CornerRadius="10"
                                Padding="10,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind MedicalExam}" Foreground="{x:Bind MedicalExamFg}" FontSize="12" />
                        </Border>
                                <Border Grid.Column="4" Background="{x:Bind FluorographyBg}" CornerRadius="10"
                                Padding="10,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Fluorography}" Foreground="{x:Bind FluorographyFg}" FontSize="12" />
                        </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Page>
