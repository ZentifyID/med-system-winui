<Page
    x:Class="MedSystem.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="32" Spacing="16">
        <TextBlock Text="Главная" Style="{StaticResource TitleTextBlockStyle}" />
        <TextBlock Text="Обзор системы" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6" />

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" MinWidth="160">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="EmployeesCount" Text="0" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Сотрудники" Opacity="0.6" />
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" MinWidth="160">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StudentsCount" Text="0" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Студенты" Opacity="0.6" />
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" MinWidth="160">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="MedicinesCount" Text="0" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Лекарства" Opacity="0.6" />
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" MinWidth="160">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="AppealsCount" Text="0" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Обращения" Opacity="0.6" />
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBlock Text="Файл базы данных:" Margin="0,16,0,0" Opacity="0.6" />
        <TextBlock x:Name="DbPathText" IsTextSelectionEnabled="True" FontSize="12" Opacity="0.8" />
    </StackPanel>
</Page>
