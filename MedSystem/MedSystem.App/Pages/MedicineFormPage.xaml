<Page
    x:Class="MedSystem.App.Pages.MedicineFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" Text="Новое лекарство"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,16" Spacing="16">
            <TextBox x:Name="NameBox" Header="Название" MaxLength="255" />
            <TextBox x:Name="DosageBox" Header="Дозировка" PlaceholderText="напр. 500 мг" MaxLength="64" />
            <NumberBox x:Name="QuantityBox" Header="Количество" Minimum="0" Maximum="100000"
                       SpinButtonPlacementMode="Compact" SmallChange="1" Value="0" />
            <TextBox x:Name="ExpirationBox" Header="Срок годности"
                     PlaceholderText="дд.мм.гггг" MaxLength="10" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Отмена" MinWidth="110" Click="CancelButton_Click" />
            <Button Content="Сохранить" Style="{StaticResource AccentButtonStyle}"
                    MinWidth="130" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Page>
