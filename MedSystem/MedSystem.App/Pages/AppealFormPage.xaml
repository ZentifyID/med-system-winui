<Page
    x:Class="MedSystem.App.Pages.AppealFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" Text="Новое обращение"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <ScrollViewer Grid.Row="1" Margin="0,16,0,16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Center">

                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <NumberBox x:Name="NumberBox" Grid.Row="0" Grid.Column="0"
                               Header="Номер обращения" Minimum="1" Maximum="1000000"
                               SpinButtonPlacementMode="Compact" />
                    <TextBox x:Name="CreatedAtBox" Grid.Row="0" Grid.Column="1"
                             Header="Дата обращения" PlaceholderText="дд.мм.гггг" MaxLength="10" />

                    <AutoSuggestBox x:Name="SenderBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Header="Отправитель"
                                    PlaceholderText="Начните вводить ФИО..."
                                    TextMemberPath="Display"
                                    TextChanged="SenderBox_TextChanged"
                                    SuggestionChosen="SenderBox_SuggestionChosen" />

                    <TextBox x:Name="BirthDateBox" Grid.Row="2" Grid.Column="0"
                             Header="Дата рождения" PlaceholderText="дд.мм.гггг" MaxLength="10" />
                    <TextBox x:Name="ParentPhoneBox" Grid.Row="2" Grid.Column="1"
                             Header="Телефон родителя" PlaceholderText="+7..." MaxLength="20" />
                </Grid>

                <TextBox x:Name="GroupNameBox" Header="Группа / принадлежность" MaxLength="64" />

                <TextBox x:Name="ComplaintsBox" Header="Жалобы"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="90" />

                <AutoSuggestBox x:Name="DiagnosisBox"
                                Header="Диагноз (МКБ)"
                                PlaceholderText="Начните вводить код или название..."
                                TextChanged="DiagnosisBox_TextChanged" />

                <TextBox x:Name="ActionsBox" Header="Действия и рекомендации"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="90" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12"
                    HorizontalAlignment="Center">
            <Button Content="Сохранить" Style="{StaticResource AccentButtonStyle}"
                    MinWidth="130" Click="SaveButton_Click" />
            <Button Content="Отмена" MinWidth="110" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Page>
