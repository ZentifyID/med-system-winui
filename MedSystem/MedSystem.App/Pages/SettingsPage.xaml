<Page
    x:Class="MedSystem.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="32,24,32,24" Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
        <TextBlock Text="Настройки" Style="{StaticResource TitleTextBlockStyle}" />

        <Border CornerRadius="8" BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <StackPanel Padding="20,16" Spacing="10">
                <TextBlock Text="Тема оформления" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButtons x:Name="ThemeRadios" SelectionChanged="ThemeRadios_SelectionChanged">
                    <x:String>Как в системе</x:String>
                    <x:String>Светлая</x:String>
                    <x:String>Тёмная</x:String>
                </RadioButtons>
            </StackPanel>
        </Border>

        <Border CornerRadius="8" BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <StackPanel Padding="20,16" Spacing="6">
                <TextBlock Text="О программе" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Med System — учёт обращений, сотрудников, студентов и лекарств медпункта колледжа."
                           TextWrapping="Wrap" Opacity="0.7" />
                <TextBlock x:Name="DbPathText" IsTextSelectionEnabled="True" FontSize="12" Opacity="0.6"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
