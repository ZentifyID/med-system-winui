<Page
    x:Class="MedSystem.App.Pages.OrderMedicinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MedSystem.App.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Заказ лекарств" Style="{StaticResource TitleTextBlockStyle}"
                   HorizontalAlignment="Center" />
        <TextBlock Grid.Row="1" Margin="0,8,0,16" Opacity="0.6" MaxWidth="900" HorizontalAlignment="Center"
                   Text="Отмеченные позиции будут списаны, вместо них добавятся новые партии с указанным количеством и сроком годности."
                   TextWrapping="Wrap" />

        <ListView x:Name="OrderList" Grid.Row="2" SelectionMode="None"
                  MaxWidth="900" HorizontalAlignment="Center">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:OrderRow">
                    <Grid Padding="4,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" MinWidth="32"
                                  IsChecked="{x:Bind Selected, Mode=TwoWay}" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" />
                            <TextBlock Text="{x:Bind CurrentInfo}" FontSize="12" Opacity="0.6" />
                        </StackPanel>

                        <NumberBox Grid.Column="2" Header="Новое кол-во" MinWidth="140"
                                   Minimum="1" Maximum="100000" SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind NewQuantity, Mode=TwoWay}" />

                        <TextBox Grid.Column="3" Header="Новый срок годности" MinWidth="160"
                                 PlaceholderText="дд.мм.гггг" MaxLength="10"
                                 Text="{x:Bind NewExpiration, Mode=TwoWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" Margin="0,12,0,0"
                    HorizontalAlignment="Center">
            <Button Content="Оформить заказ" Style="{StaticResource AccentButtonStyle}"
                    MinWidth="150" Click="ConfirmButton_Click" />
            <Button Content="Отмена" MinWidth="110" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Page>
