<Page
    x:Class="MedSystem.App.Pages.EmployeesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MedSystem.App.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0">
            <TextBlock Text="Сотрудники" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="CountText" Text="" VerticalAlignment="Bottom"
                       HorizontalAlignment="Right" Opacity="0.6" />
        </Grid>

        <!-- Поиск -->
        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     PlaceholderText="Поиск по ФИО..."
                     TextChanged="SearchBox_TextChanged" />
            <ComboBox x:Name="FilterBox" Grid.Column="1" Margin="12,0,0,0"
                      MinWidth="200" SelectedIndex="0"
                      SelectionChanged="FilterBox_SelectionChanged">
                <x:String>Все сотрудники</x:String>
                <x:String>Просроченные</x:String>
                <x:String>Истекают (2 недели)</x:String>
            </ComboBox>
        </Grid>

        <!-- Шапка таблицы -->
        <Grid Grid.Row="2" Padding="16,8" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ФИО" FontSize="12" Opacity="0.6" />
            <TextBlock Grid.Column="1" Text="Принадлежность" FontSize="12" Opacity="0.6" />
            <TextBlock Grid.Column="2" Text="Санминимум" FontSize="12" Opacity="0.6" />
            <TextBlock Grid.Column="3" Text="Медосмотр" FontSize="12" Opacity="0.6" />
            <TextBlock Grid.Column="4" Text="Флюорография" FontSize="12" Opacity="0.6" />
        </Grid>

        <!-- Список -->
        <ListView x:Name="EmployeesList" Grid.Row="3" SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:EmployeeRow">
                    <Grid Padding="4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind FullName}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Affiliation}" Opacity="0.8" />
                        <TextBlock Grid.Column="2" Text="{x:Bind Sanminimum}" Opacity="0.8" />
                        <TextBlock Grid.Column="3" Text="{x:Bind MedicalExam}" Opacity="0.8" />
                        <TextBlock Grid.Column="4" Text="{x:Bind Fluorography}" Opacity="0.8" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
